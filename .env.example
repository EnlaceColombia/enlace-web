# URL pública del sitio (para vista previa en WhatsApp / redes)
VITE_SITE_URL=https://www.enlacecolombia.org

# Imagen de vista previa (opcional). Si no se define, usa {VITE_SITE_URL}/og-image.jpg
# VITE_SITE_OG_IMAGE_URL=https://www.enlacecolombia.org/og-image.jpg

# Supabase (público — cliente / backoffice login)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your-publishable-key

# Opcional: solo servidor (Vercel). Mejora lecturas si RLS falla. NUNCA en VITE_.
SUPABASE_SERVICE_ROLE_KEY=

# Analytics (opcional)
VITE_GA_MEASUREMENT_ID=

# Horario en vivo (opcional, default UTC-5)
LIVE_UTC_OFFSET=-5
