# URL pública del sitio (para vista previa en WhatsApp / redes)
VITE_SITE_URL=https://www.enlacecolombia.org

# Imagen de vista previa (opcional). Si no se define, usa {VITE_SITE_URL}/og-image.png
# VITE_SITE_OG_IMAGE_URL=https://www.enlacecolombia.org/og-image.png

# SEO — dominio canónico para sitemap, robots.txt y meta tags
# VITE_SITE_URL=https://www.enlacecolombia.org

# Supabase (público — cliente / backoffice login)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your-publishable-key

# Clave secreta de Supabase (solo servidor, NUNCA VITE_). Reemplaza a service_role.
# Dashboard → Settings → API Keys → Secret keys → ícono del ojo → copiar
# Puedes usar cualquiera de estos nombres en Vercel:
SUPABASE_SECRET_KEY=
# SUPABASE_SERVICE_ROLE_KEY=   (nombre legacy, también válido)

# Analytics (opcional)
VITE_GA_MEASUREMENT_ID=

# Horario en vivo (opcional, default UTC-5)
LIVE_UTC_OFFSET=-5
